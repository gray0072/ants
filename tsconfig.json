{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./ts",
    "declaration": false,
    "noImplicitAny": false,
    "noEmit": false
  },
  "include": ["ts/**/*.ts"],
  "exclude": ["node_modules"]
}